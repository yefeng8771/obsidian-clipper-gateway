# ===========================================================
# obsidian-clipper-gateway —— 环境变量模板
# 复制为 .env 后填值，所有服务共用此文件
# ===========================================================

# ---- 反代域名 ----
# 主入口：https://${DOMAIN}/api  （userscript 和浏览器扩展指向这里）
# FNS  ：https://sync.${DOMAIN}  （本机 Obsidian fast-note-sync plugin 指向这里）
DOMAIN=example.com
ACME_EMAIL=you@example.com

# ===========================================================
# web_clipper
# ===========================================================

# 客户端鉴权 Bearer Token（userscript / 浏览器扩展都用它）
# 强烈建议用 `openssl rand -hex 32` 生成
API_KEY=replace-me-with-a-long-random-string

# 文件上传上限（30MB）
MAX_FILE_SIZE=31457280
ALLOWED_EXTENSIONS=.html,.htm

# ---- GitHub Pages（HTML 快照托管，仅浏览器扩展走这条） ----
GITHUB_REPO=your_github_user/your_clips_repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_PAGES_DOMAIN=https://your_github_user.github.io/your_clips_repo
GITHUB_PAGES_MAX_RETRIES=60

# ---- OpenAI（生成摘要 + 标签） ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3

# ---- Telegram 通知（可选；留空则不发） ----
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================================
# fast-note-sync-service
# ===========================================================

# 在 fast-note-sync 后台 "Copy API Configuration" 拿到的 token
FNS_TOKEN=replace-me-with-fns-token

# 默认 vault 名 / 剪藏落到 vault 的子目录
FNS_VAULT=Inbox
FNS_FOLDER=Clippings

# ===========================================================
# Local REST API 兼容层（vault_api.py）
# ===========================================================

# 自动给每条 vault 写入注入 AI 摘要 + 标签 frontmatter
# 默认关闭：脚本本身可能已经做过结构化，再开会双花钱
VAULT_AI_ENRICH=false

# 每次 vault 写入都丢一条 Telegram 通知
VAULT_NOTIFY=false
